FROM --platform=linux/386 docker.io/i386/debian:buster
ARG DEBIAN_FRONTEND=noninteractive

RUN echo "deb [trusted=yes] http://archive.debian.org/debian buster main contrib non-free" \
  > /etc/apt/sources.list && \
	echo "deb [trusted=yes] http://archive.debian.org/debian-security buster/updates main" \
	>> /etc/apt/sources.list

# ===== Core build tools =====
RUN apt-get clean && apt-get update && apt-get -y upgrade && \
	apt-get -y install \
	gcc g++ make cmake autoconf automake \
	libtool pkg-config dpkg-dev git \
	gdb binutils flex bison \
	valgrind patch file \
	curl wget zip unzip tar \
	netcat-openbsd ca-certificates strace \
	nano vim less tree ncdu htop \
	python3 python3-pip python3-setuptools \
	nodejs ruby lua5.3 luajit

# ===== Lightweight pip packages only =====
RUN pip3 install --no-cache-dir flask requests pyyaml pytest

# ===== Clean up aggressively =====
RUN apt-get clean && \
	rm -rf /var/lib/apt/lists/* /var/cache/apt/* \
	/var/lib/dpkg/cache/* /usr/share/doc /usr/share/man \
	/tmp/* /var/log/apt/* /root/.cache /root/.cache/pip

RUN useradd -m user && echo "user:password" | chpasswd

COPY --chown=user:user ./examples /home/user/examples
RUN chmod -R +x /home/user/examples/lua

WORKDIR /home/user/
ENV HOME="/home/user" TERM="xterm" USER="user" SHELL="/bin/bash" EDITOR="vim" LANG="C.UTF-8"

RUN echo 'root:password' | chpasswd

CMD [ "/bin/bash" ]